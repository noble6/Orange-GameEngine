digraph RenderGraph {
  rankdir=LR;
  node [shape=box, fontname="Courier"];
  pass0 [label="visibility", color=black, fontcolor=black];
  pass1 [label="depth_prepass", color=black, fontcolor=black];
  pass2 [label="shadow", color=black, fontcolor=black];
  pass3 [label="lighting", color=black, fontcolor=black];
  pass4 [label="volumetric_fog", color=gray, fontcolor=gray];
  pass5 [label="transparent", color=black, fontcolor=black];
  pass6 [label="post", color=black, fontcolor=black];
  pass0 -> pass1;
  pass0 -> pass2;
  pass0 -> pass3;
  pass1 -> pass3;
  pass2 -> pass3;
  pass3 -> pass4;
  pass3 -> pass5;
  pass4 -> pass6;
  pass5 -> pass6;
  res_backbuffer [label="backbuffer", shape=ellipse, color=blue, fontcolor=blue];
  pass6 -> res_backbuffer [color=blue];
  res_hdr_color [label="hdr_color", shape=ellipse, color=blue, fontcolor=blue];
  pass3 -> res_hdr_color [color=blue];
  pass4 -> res_hdr_color [color=blue];
  pass5 -> res_hdr_color [color=blue];
  res_hdr_color -> pass6 [color=green];
  res_shadow_map [label="shadow_map", shape=ellipse, color=blue, fontcolor=blue];
  pass2 -> res_shadow_map [color=blue];
  res_shadow_map -> pass3 [color=green];
  res_depth [label="depth", shape=ellipse, color=blue, fontcolor=blue];
  pass1 -> res_depth [color=blue];
  res_depth -> pass3 [color=green];
  res_depth -> pass4 [color=green];
  res_depth -> pass5 [color=green];
  res_visible_list [label="visible_list", shape=ellipse, color=blue, fontcolor=blue];
  pass0 -> res_visible_list [color=blue];
  res_visible_list -> pass1 [color=green];
  res_visible_list -> pass2 [color=green];
  res_visible_list -> pass3 [color=green];
}
